#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

say() {
  printf '%s\n' "$*"
}

run_step() {
  local label="$1"
  shift

  say "==> ${label}"
  "$@"
}

cd "$REPO_ROOT"

run_step "pnpm lint" pnpm lint
run_step "pnpm build" pnpm build
run_step "pnpm test" pnpm test

say "all checks passed"
